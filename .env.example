# Copy to .env.local and fill in. Never commit .env.local.

# --- Phase 0 (required to boot) ---
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# --- Phase 1 ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Set to 1 to show seeded dev-account hints on /login (local dev only)
NEXT_PUBLIC_SHOW_DEV_HINTS=0

COMPUTE_BASE_URL="http://localhost:8000"
COMPUTE_SHARED_SECRET=""

OPENCAGE_API_KEY=""

# --- Phase 2 (LLM router) ---
# Gemini (REQUIRED for AI features) — free tier, no card:
#   https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# Groq fallback (OPTIONAL, free): https://console.groq.com/keys
GROQ_API_KEY=""
# Paid providers (OPTIONAL — only if you want Claude/GPT-4o for long-form):
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

RESEND_API_KEY=""

# AES-256-GCM key for KYC/bank field encryption — 32 bytes base64.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=""

R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""

# --- Phase 3 ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
