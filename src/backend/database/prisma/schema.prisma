// Prisma 7 — datasource URL is provided via prisma.config.ts (no `url` here).
// Models will be added in Phase 1 (User, AuthIdentity, Session, Profile, Chart per SoW §10).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}
