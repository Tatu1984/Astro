// Prisma 7 — datasource URL is provided via prisma.config.ts (no `url` here).
// Phase 1 slice of SoW §10: User/Account/Session/VerificationToken (Auth.js
// adapter shape) + Profile + Chart. Other tables (Subscription, Post,
// Notification, Embedding, etc.) land in later phases.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// =========================
// AUTH (Auth.js v5 adapter shape)
// =========================

enum UserRole {
  USER
  ASTROLOGER
  ADMIN
  MODERATOR
}

enum AstroSystem {
  WESTERN
  VEDIC
  BOTH
}

model User {
  id            String      @id @default(cuid())
  email         String?     @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  phone         String?     @unique
  role          UserRole    @default(USER)
  systemPref    AstroSystem @default(BOTH)
  locale        String      @default("en")
  timezone      String?
  bio           String?
  referralCode  String      @unique @default(cuid())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  accounts             Account[]
  sessions             Session[]
  profiles             Profile[]
  charts               Chart[]
  predictions          Prediction[]        @relation("UserPredictions")
  reports              Report[]            @relation("UserReports")
  compatibilities      Compatibility[]     @relation("UserCompatibilities")
  posts                Post[]              @relation("UserPosts")
  comments             Comment[]           @relation("UserComments")
  reactions            Reaction[]          @relation("UserReactions")
  chatSessions         AiChatSession[]     @relation("UserChatSessions")
  astrologerProfile    AstrologerProfile?  @relation("AstrologerProfileUser")
  onboardedAstrologers AstrologerProfile[] @relation("AstrologerOnboardedBy")
  bookings             Booking[]           @relation("UserBookings")
  reviews              Review[]            @relation("UserReviews")
  payoutsProcessed     Payout[]            @relation("PayoutProcessor")

  @@index([deletedAt])
}

// OAuth identities — Auth.js calls these "Account"
model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String // "oauth" | "email" | "credentials"
  provider          String // "google" | "apple" | "facebook" | "credentials"
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =========================
// ASTROLOGER PROFILE (admin-onboarded)
// =========================

enum KycType {
  PAN
  AADHAAR
  PASSPORT
  VOTER_ID
  DRIVING_LICENSE
}

enum AstrologerStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

// Sensitive fields (kycNumber, bankAccountNumber, upiId) are stored
// plain-text in Phase 1. Application-level encryption + audit trail land
// before any production data flows in. NeonDB encrypts at rest; the gap
// is in-app log/query exposure.
model AstrologerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation("AstrologerProfileUser", fields: [userId], references: [id], onDelete: Cascade)

  // Personal
  fullName       String
  phone          String
  alternatePhone String?

  // Address
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  postalCode   String
  country      String  @default("IN")

  // KYC
  kycType       KycType
  kycNumber     String // sensitive — encrypt before prod
  kycVerifiedAt DateTime?
  kycDocUrl     String?

  // Professional
  qualifications  String?  @db.Text
  yearsExperience Int?
  specialties     String[]
  languages       String[] @default([])
  bio             String?  @db.Text

  // Banking — sensitive — encrypt before prod
  bankAccountName   String?
  bankAccountNumber String?
  bankIfsc          String?
  upiId             String?

  status        AstrologerStatus @default(PENDING)
  onboardedById String?
  onboardedBy   User?            @relation("AstrologerOnboardedBy", fields: [onboardedById], references: [id], onDelete: SetNull)

  // Aggregated review stats — recomputed on each new review
  averageRating Float @default(0)
  ratingCount   Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services           AstrologerService[]
  schedules          AstrologerSchedule[]
  scheduleExceptions ScheduleException[]
  bookings           Booking[]
  reviews            Review[]
  ledger             WalletLedger[]
  payouts            Payout[]

  @@index([status])
  @@index([onboardedById])
}

// =========================
// MARKETPLACE: services, schedule, bookings, payments, payouts
// =========================

enum ServiceKind {
  CHAT
  VOICE
  VIDEO
  REPORT
}

model AstrologerService {
  id                  String            @id @default(cuid())
  astrologerProfileId String
  astrologerProfile   AstrologerProfile @relation(fields: [astrologerProfileId], references: [id], onDelete: Cascade)

  kind        ServiceKind
  title       String
  description String?     @db.Text
  durationMin Int
  priceInr    Int
  isActive    Boolean     @default(true)

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([astrologerProfileId])
  @@index([astrologerProfileId, isActive])
  @@index([kind])
}

model AstrologerSchedule {
  id                  String            @id @default(cuid())
  astrologerProfileId String
  astrologerProfile   AstrologerProfile @relation(fields: [astrologerProfileId], references: [id], onDelete: Cascade)

  weekday      Int // 0=Sunday .. 6=Saturday
  startMinutes Int
  endMinutes   Int
  timezone     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([astrologerProfileId])
  @@index([astrologerProfileId, weekday])
}

model ScheduleException {
  id                  String            @id @default(cuid())
  astrologerProfileId String
  astrologerProfile   AstrologerProfile @relation(fields: [astrologerProfileId], references: [id], onDelete: Cascade)

  date         DateTime @db.Date
  isAvailable  Boolean
  startMinutes Int?
  endMinutes   Int?

  createdAt DateTime @default(now())

  @@index([astrologerProfileId])
  @@index([astrologerProfileId, date])
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  REFUNDED
}

model Booking {
  id                  String        @id @default(cuid())
  userId              String
  astrologerProfileId String
  serviceId           String
  scheduledAt         DateTime
  durationMin         Int
  status              BookingStatus @default(PENDING_PAYMENT)

  priceInr         Int
  platformFeeInr   Int @default(0)
  astrologerNetInr Int @default(0)

  razorpayOrderId   String?
  razorpayPaymentId String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  cancelledAt DateTime?

  user              User              @relation("UserBookings", fields: [userId], references: [id], onDelete: Cascade)
  astrologerProfile AstrologerProfile @relation(fields: [astrologerProfileId], references: [id], onDelete: Cascade)
  service           AstrologerService @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  consultSession    ConsultSession?
  review            Review?

  @@index([userId])
  @@index([astrologerProfileId])
  @@index([serviceId])
  @@index([status])
  @@index([astrologerProfileId, scheduledAt])
  @@index([userId, scheduledAt])
}

model ConsultSession {
  id        String  @id @default(cuid())
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  dailyRoomName        String
  dailyRoomUrl         String
  dailyTokenUser       String?
  dailyTokenAstrologer String?

  startedAt         DateTime?
  endedAt           DateTime?
  durationActualSec Int?
  astrologerNotes   String?   @db.Text
  recordingUrl      String?

  createdAt DateTime @default(now())
}

model Review {
  id        String  @id @default(cuid())
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("UserReviews", fields: [userId], references: [id], onDelete: Cascade)

  astrologerProfileId String
  astrologerProfile   AstrologerProfile @relation(fields: [astrologerProfileId], references: [id], onDelete: Cascade)

  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  @@index([astrologerProfileId, createdAt])
  @@index([userId])
}

enum LedgerKind {
  EARNING
  PAYOUT
  ADJUSTMENT
  REFUND
}

enum LedgerRefType {
  BOOKING
  PAYOUT
  MANUAL
}

model WalletLedger {
  id                  String            @id @default(cuid())
  astrologerProfileId String
  astrologerProfile   AstrologerProfile @relation(fields: [astrologerProfileId], references: [id], onDelete: Cascade)

  kind            LedgerKind
  amountInr       Int // signed (positive = credit, negative = debit)
  refType         LedgerRefType
  refId           String?
  balanceAfterInr Int
  description     String?
  createdAt       DateTime      @default(now())

  payouts Payout[] @relation("PayoutLedgerEntry")

  @@index([astrologerProfileId, createdAt])
  @@index([astrologerProfileId, kind])
}

enum PayoutStatus {
  REQUESTED
  APPROVED
  PROCESSING
  COMPLETED
  FAILED
  REJECTED
}

model Payout {
  id                  String            @id @default(cuid())
  astrologerProfileId String
  astrologerProfile   AstrologerProfile @relation(fields: [astrologerProfileId], references: [id], onDelete: Cascade)

  amountInr        Int
  status           PayoutStatus @default(REQUESTED)
  razorpayPayoutId String?

  requestedAt       DateTime  @default(now())
  completedAt       DateTime?
  processedByUserId String?
  processedBy       User?     @relation("PayoutProcessor", fields: [processedByUserId], references: [id], onDelete: SetNull)

  ledgerEntryId String?
  ledgerEntry   WalletLedger? @relation("PayoutLedgerEntry", fields: [ledgerEntryId], references: [id], onDelete: SetNull)

  @@index([astrologerProfileId])
  @@index([status])
  @@index([astrologerProfileId, status])
  @@index([processedByUserId])
}

// =========================
// PROFILES (multi-profile per account, for chart computation)
// =========================

enum ProfileKind {
  SELF
  PARTNER
  CHILD
  FRIEND
  CELEBRITY
  OTHER
}

model Profile {
  id          String      @id @default(cuid())
  userId      String
  kind        ProfileKind
  fullName    String
  birthDate   DateTime
  birthTime   DateTime?
  unknownTime Boolean     @default(false)
  birthPlace  String
  latitude    Decimal     @db.Decimal(9, 6)
  longitude   Decimal     @db.Decimal(9, 6)
  timezone    String
  gender      String?
  notes       String?
  isPrivate   Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  charts         Chart[]
  predictions    Prediction[]
  reports        Report[]
  chatSessions   AiChatSession[]
  compatibilityA Compatibility[] @relation("CompatibilityA")
  compatibilityB Compatibility[] @relation("CompatibilityB")

  @@index([userId])
  @@index([kind])
}

// =========================
// CHARTS (deterministic compute output, cached by inputHash)
// =========================

enum HouseSystem {
  PLACIDUS
  WHOLE_SIGN
  KOCH
  EQUAL
  VEDIC_EQUAL
}

enum ChartKind {
  NATAL
  TRANSIT
  PROGRESSED_SECONDARY
  PROGRESSED_SOLAR_ARC
  SOLAR_RETURN
  LUNAR_RETURN
  ANNUAL_VARSHA
  COMPOSITE
  DAVISON
  HORARY
  ELECTIONAL
  DIVISIONAL
}

model Chart {
  id           String      @id @default(cuid())
  userId       String
  profileId    String?
  kind         ChartKind
  system       AstroSystem
  houseSystem  HouseSystem
  divisionalIx Int?
  computedAt   DateTime    @default(now())
  payload      Json
  inputHash    String
  expiresAt    DateTime?

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile      Profile?        @relation(fields: [profileId], references: [id], onDelete: SetNull)
  predictions  Prediction[]
  reports      Report[]
  chatSessions AiChatSession[]

  @@unique([userId, kind, system, houseSystem, inputHash])
  @@index([userId])
  @@index([profileId])
  @@index([kind, system])
}

// =========================
// PREDICTIONS / READINGS (LLM-rendered, cached per period)
// =========================

enum PredictionKind {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  TRANSIT_FORECAST
  DASHA_VIMSHOTTARI
}

model Prediction {
  id           String         @id @default(cuid())
  userId       String
  profileId    String?
  chartId      String?
  kind         PredictionKind
  periodStart  DateTime
  periodEnd    DateTime
  facts        Json
  payload      Json // structured LLM output (headline, body, domains, etc.)
  text         String         @db.Text
  llmProvider  String
  llmModel     String
  promptHash   String
  inputTokens  Int            @default(0)
  outputTokens Int            @default(0)
  costUsdMicro Int            @default(0)
  createdAt    DateTime       @default(now())

  user    User     @relation("UserPredictions", fields: [userId], references: [id], onDelete: Cascade)
  profile Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  chart   Chart?   @relation(fields: [chartId], references: [id], onDelete: SetNull)

  @@unique([userId, profileId, kind, periodStart])
  @@index([userId, periodStart])
  @@index([profileId, kind])
}

// =========================
// COMPATIBILITY (synastry between two profiles)
// =========================

enum CompatibilityKind {
  ROMANTIC
  FRIENDSHIP
  BUSINESS
  FAMILY
}

model Compatibility {
  id           String            @id @default(cuid())
  userId       String
  kind         CompatibilityKind
  profileAId   String
  profileBId   String
  score        Int
  details      Json
  text         String?           @db.Text
  llmProvider  String?
  llmModel     String?
  inputTokens  Int               @default(0)
  outputTokens Int               @default(0)
  costUsdMicro Int               @default(0)
  createdAt    DateTime          @default(now())

  user     User    @relation("UserCompatibilities", fields: [userId], references: [id], onDelete: Cascade)
  profileA Profile @relation("CompatibilityA", fields: [profileAId], references: [id], onDelete: Cascade)
  profileB Profile @relation("CompatibilityB", fields: [profileBId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, profileAId, profileBId])
  @@index([userId, createdAt])
}

// =========================
// LONG-FORM REPORTS (LLM-generated markdown)
// =========================

enum ReportKind {
  NATAL_FULL
  CAREER_WEALTH
  LOVE_MARRIAGE
  HEALTH
  EDUCATION
  SPIRITUAL
}

model Report {
  id           String     @id @default(cuid())
  userId       String
  profileId    String?
  chartId      String?
  kind         ReportKind
  title        String
  bodyMarkdown String     @db.Text
  pdfUrl       String?
  llmProvider  String?
  llmModel     String?
  inputTokens  Int        @default(0)
  outputTokens Int        @default(0)
  costUsdMicro Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user    User     @relation("UserReports", fields: [userId], references: [id], onDelete: Cascade)
  profile Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  chart   Chart?   @relation(fields: [chartId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([profileId, kind])
}

// =========================
// COMMUNITY FEED
// =========================

enum PostVisibility {
  PUBLIC
  ANONYMOUS
  PRIVATE
}

model Post {
  id         String         @id @default(cuid())
  userId     String
  body       String         @db.Text
  visibility PostVisibility @default(PUBLIC)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?

  user      User       @relation("UserPosts", fields: [userId], references: [id], onDelete: Cascade)
  comments  Comment[]
  reactions Reaction[]

  @@index([userId])
  @@index([visibility, createdAt])
  @@index([deletedAt])
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  userId    String
  body      String    @db.Text
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation("UserComments", fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([userId])
}

model Reaction {
  id     String @id @default(cuid())
  postId String
  userId String
  type   String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation("UserReactions", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
  @@index([postId])
}

// =========================
// AI CHAT WITH CHART
// =========================

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

model AiChatSession {
  id        String   @id @default(cuid())
  userId    String
  profileId String?
  chartId   String?
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User            @relation("UserChatSessions", fields: [userId], references: [id], onDelete: Cascade)
  profile  Profile?        @relation(fields: [profileId], references: [id], onDelete: SetNull)
  chart    Chart?          @relation(fields: [chartId], references: [id], onDelete: SetNull)
  messages AiChatMessage[]

  @@index([userId, updatedAt])
}

model AiChatMessage {
  id           String   @id @default(cuid())
  sessionId    String
  role         ChatRole
  content      String   @db.Text
  llmProvider  String?
  llmModel     String?
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costUsdMicro Int      @default(0)
  createdAt    DateTime @default(now())

  session AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

// =========================
// LLM call log (per-request cost + latency tracking)
// =========================

model LlmCallLog {
  id           String   @id @default(cuid())
  userId       String?
  route        String
  provider     String
  model        String
  promptHash   String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costUsdMicro Int      @default(0)
  latencyMs    Int      @default(0)
  status       String
  error        String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([provider, createdAt])
  @@index([route, createdAt])
}
